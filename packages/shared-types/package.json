{
  "name": "@grapix/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fixtures:emit": "npm run build && node scripts/emit-fixtures.mjs",
    "fixtures:check": "npm run build && node scripts/emit-fixtures.mjs --check"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
