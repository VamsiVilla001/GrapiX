      "entryPoints": {
        "vertex": "vs_main",
        "fragment": "fs_main"
      },
      "vertexInput": {
        "mode": "generated",
        "note": "Unit quad produced from @builtin(vertex_index); no vertex buffer, draw 6 vertices as a triangle list."
      },
      "uniforms": {
        "QuadUniforms": {
          "group": 0,
          "binding": 0,
          "sizeBytes": 96,
          "alignBytes": 16,
          "fields": [
            { "name": "transform", "type": "mat4x4<f32>", "offsetBytes": 0, "sizeBytes": 64, "matrixOrder": "column-major" },
            { "name": "fill_color", "type": "vec4<f32>", "offsetBytes": 64, "sizeBytes": 16 },
            { "name": "params", "type": "vec4<f32>", "offsetBytes": 80, "sizeBytes": 16 }
          ]
        }
      }
    }
  },
  "blendModes": [
    { "id": 0, "name": "normal", "implemented": true, "color": "src*ONE + dst*ONE_MINUS_SRC_ALPHA", "alpha": "src*ONE + dst*ONE_MINUS_SRC_ALPHA", "note": "premultiplied source-over" },
    { "id": 1, "name": "multiply", "implemented": true, "color": "src*DST + dst*ONE_MINUS_SRC_ALPHA", "alpha": "src*ONE + dst*ONE_MINUS_SRC_ALPHA", "note": "Adobe Multiply; premultiplied, matches PixiJS" },
    { "id": 2, "name": "screen", "implemented": true, "color": "src*ONE + dst*ONE_MINUS_SRC", "alpha": "src*ONE + dst*ONE_MINUS_SRC_ALPHA", "note": "Adobe Screen; premultiplied, matches PixiJS" },
    { "id": 3, "name": "add", "implemented": true, "color": "src*ONE + dst*ONE", "alpha": "src*ONE + dst*ONE", "note": "linear dodge / additive" },
    { "id": 4, "name": "darken", "implemented": true, "color": "MIN(src, dst)", "alpha": "MIN(src, dst)", "note": "Adobe Darken via GPU min op; matches PixiJS min" },
    { "id": 5, "name": "lighten", "implemented": true, "color": "MAX(src, dst)", "alpha": "MAX(src, dst)", "note": "Adobe Lighten via GPU max op; matches PixiJS max" }
  ],
  "blendModesUnimplemented": [
    { "name": "overlay", "reason": "PixiJS core silently aliases overlay to screen; needs shader compositing to be correct" },
    { "name": "subtract", "reason": "reverse-subtract over premultiplied alpha needs shader compositing" },
